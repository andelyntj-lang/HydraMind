<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme forced to Light mode. -->
    <style name="Base.Theme.UAS_PEMROGRAMAN_MOBILE" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Force light background and surface colors -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@android:color/black</item>
        <item name="colorContainer">@android:color/white</item>
        <item name="colorOnContainer">@android:color/black</item>
        <item name="colorSurfaceVariant">@android:color/white</item>
        <item name="colorOnSurfaceVariant">@android:color/black</item>
    </style>

    <style name="Theme.UAS_PEMROGRAMAN_MOBILE" parent="Base.Theme.UAS_PEMROGRAMAN_MOBILE" />

    <!-- Style untuk foto profil bulat -->
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
</resources>