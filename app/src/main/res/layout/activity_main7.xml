<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#42A5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_navigation">

        <!-- Tombol Back -->

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengingat Pintar"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <!-- Konten Utama (Kartu Putih) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Mascot & Balon Ucapan -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivMascot"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:contentDescription="Maskot"
                        android:src="@drawable/whatsapp_image_2026_06_16_at_12_31_34" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/ivMascot"
                        android:background="@android:color/white"
                        android:elevation="2dp"
                        android:padding="12dp"
                        android:text="Waktunya minum air!"
                        android:textColor="#333333"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Circular Progress -->
                <TextView
                    android:id="@+id/tvWaterProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/1200ml"
                    android:textColor="#1976D2"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:gravity="center">

                    <ProgressBar
                        android:id="@+id/pbWaterCircle"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="194dp"
                        android:layout_height="177dp"
                        android:indeterminate="false"
                        android:max="1200"
                        android:progress="0"
                        android:progressDrawable="@drawable/circular_progress" />
                </RelativeLayout>

                <!-- Tombol Kontrol Air -->
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="-40dp">

                    <!-- Tombol Tambah Air -->

                    <LinearLayout
                        android:id="@+id/btnAddWaterManual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:color/white"
                        android:clickable="true"
                        android:elevation="4dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvSelectedCupText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200 ml"
                            android:textColor="#1976D2"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivSelectedCupIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:contentDescription="Tambah"
                            android:src="@drawable/lima_takeaway"
                            app:tint="#1976D2" />
                    </LinearLayout>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnChangeCup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBottom="@id/btnAddWaterManual"
                        android:layout_marginStart="1dp"
                        android:layout_marginBottom="10dp"
                        android:layout_toEndOf="@id/btnAddWaterManual"
                        android:contentDescription="Ganti Cangkir"
                        android:src="@android:drawable/ic_menu_edit"
                        app:backgroundTint="@android:color/white"
                        app:fabSize="mini"
                        app:tint="#1976D2" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Catatan Hari Ini +"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Timeline Hari Ini -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIntakeTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:listitem="@layout/item_intake" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color" />

</RelativeLayout>